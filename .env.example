# Copy this file to .env.local and fill in real values.
# .env.local stays on your machine; git never uploads it.

# "fixture" renders built-in sample data, no Google credentials needed.
# Switch to "sheets" once the three GOOGLE_* values below are filled in.
DATA_SOURCE=fixture

# From the Sheet URL: docs.google.com/spreadsheets/d/<THIS_LONG_ID>/edit
GOOGLE_SHEETS_ID=

# From the service account JSON key file, the "client_email" field.
GOOGLE_SERVICE_ACCOUNT_EMAIL=

# From the JSON key file, the "private_key" field. Paste the ENTIRE value
# in double quotes, keeping the \n sequences exactly as they appear:
# GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIE...\n-----END PRIVATE KEY-----\n"
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY=

# Optional: Drive folder id holding receipt images. When set, the image
# proxy only serves files inside this folder.
GOOGLE_DRIVE_RECEIPTS_FOLDER_ID=

# How long pages may serve cached data before re-reading the Sheet.
REVALIDATE_SECONDS=60

# Optional: "true" shows the design exploration toggles (star motif, display
# font) on deployed builds, for organizer walkthrough previews only.
NEXT_PUBLIC_SHOW_EXPLORATION=

